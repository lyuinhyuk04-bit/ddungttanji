{
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [

    {
      "src": "/api/live_status",
      "dest": "/api/live_status.js"
    },
    {
      "src": "/api/save_schedule",
      "dest": "/api/save_schedule.js"
    },
    {
      "src": "/api/schedules",
      "dest": "/api/schedules.js"
    },
    {
      "src": "/api/events",
      "dest": "/api/events.js"
    },
    {
      "src": "/api/save_events",
      "dest": "/api/save_events.js"
    },
    {
      "src": "/api/fetch_og",
      "dest": "/api/fetch_og.js"
    },
    {
      "src": "/events",
      "dest": "/index.html"
    },
    {
      "src": "/events/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
